      "source": [
        "\"\"\"\n",
        "Reusable Bubble Chart Script (Production-style)\n",
        "----------------------------------------------\n",
        "Reads two yearly tables (2024 + 2025) OR a merged table, computes:\n",
        "\n",
        "- Absolute Growth\n",
        "- YoY Growth %\n",
        "- % of Absolute Market Growth\n",
        "- Bubble size scale (derived in code)\n",
        "\n",
        "Plots a bubble chart with:\n",
        "- 3-shade red palette based on quadrant criticality vs market averages\n",
        "- Short-form labels (abbreviations)\n",
        "- Manual label offsets for known overlaps (extendable)\n",
        "- Market Avg label placed safely (no overlap)\n",
        "- Abbreviation table on the right\n",
        "\n",
        "Edge cases handled:\n",
        "- revenue_2024 == 0 -> YoY undefined (NaN); policy: skip or plot at fixed X\n",
        "- negative growth -> allowed\n",
        "- net market growth <= 0 -> guardrail (can switch to abs mode)\n",
        "- all deltas == 0 -> shares = 0\n",
        "- duplicate company rows -> aggregated\n",
        "- non-numeric -> errors early\n",
        "- extreme scale -> quantile clip + log sizing\n",
        "\n",
        "Dependencies: pandas, numpy, matplotlib\n",
        "\"\"\"\n",
        "\n",
        "from __future__ import annotations\n",
        "\n",
        "from dataclasses import dataclass\n",
        "from typing import Dict, Literal, Optional, Tuple\n",
        "\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "\n",
        "MarketShareMode = Literal[\"net\", \"abs\"]\n",
        "\n",
        "\n",
        "# --------------------------\n",
        "# Configs\n",
        "# --------------------------\n",
        "\n",
        "@dataclass(frozen=True)\n",
        "class BubbleSizeConfig:\n",
        "    method: Literal[\"linear\", \"log\"] = \"log\"\n",
        "    min_area: float = 80.0\n",
        "    max_area: float = 1800.0\n",
        "    clip_quantiles: Tuple[float, float] = (0.02, 0.98)\n",
        "    safe_constant: bool = True\n",
        "\n",
        "\n",
        "@dataclass(frozen=True)\n",
        "class PlotConfig:\n",
        "    title: str = \"Scale & Growth Comparison\"\n",
        "    xlabel: str = \"YoY Growth (%)\"\n",
        "    ylabel: str = \"% of Absolute Market Growth\"\n",
        "    alpha: float = 0.70\n",
        "    grid: bool = True\n",
        "\n",
        "    # YoY NaN (new business) handling\n",
        "    new_business_policy: Literal[\"skip\", \"set_x_to_value\"] = \"skip\"\n",
        "    new_business_x_value: float = 150.0  # used when policy == \"set_x_to_value\"\n",
        "\n",
        "    # Reference lines\n",
        "    draw_market_avg_line: bool = True\n",
        "    draw_avg_share_line: bool = True\n",
        "\n",
        "    # Abbrev table\n",
        "    show_abbrev_table: bool = True\n",
        "\n",
        "\n",
        "# --------------------------\n",
        "# Validations & utilities\n",
        "# --------------------------\n",
        "\n",
        "def validate_year_table(\n",
        "    df: pd.DataFrame,\n",
        "    revenue_col: str,\n",
        "    company_col: str = \"company\",\n",
        ") -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Validates a single-year table with columns: [company, revenue_col]\n",
        "    - company must be present and non-blank\n",
        "    - revenue must be numeric (after coercion)\n",
        "    - duplicates are aggregated (sum)\n",
        "    \"\"\"\n",
        "    if company_col not in df.columns or revenue_col not in df.columns:\n",
        "        raise ValueError(f\"Expected columns ['{company_col}', '{revenue_col}'] but got {list(df.columns)}\")\n",
        "\n",
        "    out = df[[company_col, revenue_col]].copy()\n",
        "\n",
        "    # Company clean\n",
        "    out[company_col] = out[company_col].astype(str).str.strip()\n",
        "    out.loc[out[company_col].eq(\"\") | out[company_col].isna(), company_col] = np.nan\n",
        "    if out[company_col].isna().any():\n",
        "        raise ValueError(\"Found missing/blank company names.\")\n",
        "\n",
        "    # Revenue clean\n",
        "    out[revenue_col] = pd.to_numeric(out[revenue_col], errors=\"coerce\")\n",
        "    if out[revenue_col].isna().any():\n",
        "        bad = out[out[revenue_col].isna()][company_col].tolist()\n",
        "        raise ValueError(f\"Found non-numeric/missing revenue for: {bad}\")\n",
        "\n",
        "    # Aggregate duplicates (common in exports)\n",
        "    out = out.groupby(company_col, as_index=False)[revenue_col].sum()\n",
        "\n",
        "    return out\n",
        "\n",
        "\n",
        "def merge_year_tables(\n",
        "    df_2024: pd.DataFrame,\n",
        "    df_2025: pd.DataFrame,\n",
        "    company_col: str = \"company\",\n",
        "    revenue_2024_col: str = \"revenue_2024\",\n",
        "    revenue_2025_col: str = \"revenue_2025\",\n",
        "    join: Literal[\"inner\", \"outer\"] = \"inner\",\n",
        ") -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Merge two year tables into one.\n",
        "    join='inner': strict; only companies present in both\n",
        "    join='outer': keeps all; errors if missing values exist (forces you to decide)\n",
        "    \"\"\"\n",
        "    d24 = validate_year_table(df_2024, revenue_2024_col, company_col)\n",
        "    d25 = validate_year_table(df_2025, revenue_2025_col, company_col)\n",
        "\n",
        "    merged = d24.merge(d25, on=company_col, how=join, validate=\"one_to_one\")\n",
        "\n",
        "    if join == \"outer\":\n",
        "        if merged[revenue_2024_col].isna().any() or merged[revenue_2025_col].isna().any():\n",
        "            missing_24 = merged.loc[merged[revenue_2024_col].isna(), company_col].tolist()\n",
        "            missing_25 = merged.loc[merged[revenue_2025_col].isna(), company_col].tolist()\n",
        "            raise ValueError(\n",
        "                \"Missing data after outer join.\\n\"\n",
        "                f\"- Missing 2024 for: {missing_24}\\n\"\n",
        "                f\"- Missing 2025 for: {missing_25}\\n\"\n",
        "                \"Fix input data or use join='inner'.\"\n",
        "            )\n",
        "\n",
        "    return merged\n",
        "\n",
        "\n",
        "# --------------------------\n",
        "# Metric calculations\n",
        "# --------------------------\n",
        "\n",
        "def calculate_absolute_growth(df: pd.DataFrame, revenue_2024_col: str, revenue_2025_col: str) -> pd.Series:\n",
        "    \"\"\"Absolute Growth = Y2 - Y1\"\"\"\n",
        "    return df[revenue_2025_col] - df[revenue_2024_col]\n",
        "\n",
        "\n",
        "def calculate_yoy_growth_pct(df: pd.DataFrame, revenue_2024_col: str, revenue_2025_col: str) -> pd.Series:\n",
        "    \"\"\"\n",
        "    YoY Growth (%) = (Y2/Y1 - 1)*100\n",
        "    Edge case: Y1 == 0 -> NaN (new business)\n",
        "    \"\"\"\n",
        "    y1 = df[revenue_2024_col].astype(float)\n",
        "    y2 = df[revenue_2025_col].astype(float)\n",
        "\n",
        "    with np.errstate(divide=\"ignore\", invalid=\"ignore\"):\n",
        "        yoy = (y2 / y1 - 1.0) * 100.0\n",
        "\n",
        "    yoy = yoy.where(y1 != 0, np.nan)\n",
        "    return yoy\n",
        "\n",
        "\n",
        "def calculate_market_growth_share_pct(\n",
        "    abs_growth: pd.Series,\n",
        "    mode: MarketShareMode = \"net\",\n",
        "    strict_net_guardrail: bool = True,\n",
        ") -> pd.Series:\n",
        "    \"\"\"\n",
        "    % of Absolute Market Growth\n",
        "\n",
        "    mode='net': Δ / sum(Δ) * 100\n",
        "      - if sum(Δ) <= 0, can raise or fallback to abs depending on strict_net_guardrail\n",
        "\n",
        "    mode='abs': Δ / sum(|Δ|) * 100\n",
        "      - stable even if market contraction\n",
        "      - if all Δ==0 -> returns zeros\n",
        "    \"\"\"\n",
        "    delta = abs_growth.astype(float)\n",
        "\n",
        "    if mode == \"net\":\n",
        "        denom = float(delta.sum())\n",
        "        if denom <= 0:\n",
        "            if strict_net_guardrail:\n",
        "                raise ValueError(\n",
        "                    f\"Net market growth is <= 0 (sum(Δ)={denom:.3f}). \"\n",
        "                    \"Net share becomes unstable. Use mode='abs' or verify periods.\"\n",
        "                )\n",
        "            denom = float(np.abs(delta).sum())\n",
        "            if denom == 0:\n",
        "                return pd.Series(np.zeros(len(delta)), index=delta.index)\n",
        "            return (delta / denom) * 100.0\n",
        "        return (delta / denom) * 100.0\n",
        "\n",
        "    if mode == \"abs\":\n",
        "        denom = float(np.abs(delta).sum())\n",
        "        if denom == 0:\n",
        "            return pd.Series(np.zeros(len(delta)), index=delta.index)\n",
        "        return (delta / denom) * 100.0\n",
        "\n",
        "    raise ValueError(\"mode must be 'net' or 'abs'\")\n",
        "\n",
        "\n",
        "def compute_bubble_sizes(scale: pd.Series, cfg: BubbleSizeConfig) -> pd.Series:\n",
        "    \"\"\"\n",
        "    Convert a raw scale metric (e.g., revenue_2025) into matplotlib marker areas.\n",
        "    Handles outliers with quantile clipping + log scaling.\n",
        "    \"\"\"\n",
        "    x = pd.to_numeric(scale, errors=\"coerce\").astype(float)\n",
        "    if x.isna().any():\n",
        "        raise ValueError(\"Bubble size scale contains non-numeric or missing values.\")\n",
        "\n",
        "    lo_q, hi_q = cfg.clip_quantiles\n",
        "    lo = float(x.quantile(lo_q))\n",
        "    hi = float(x.quantile(hi_q))\n",
        "    x = x.clip(lower=lo, upper=hi)\n",
        "\n",
        "    if cfg.method == \"log\":\n",
        "        t = np.log1p(x)\n",
        "    elif cfg.method == \"linear\":\n",
        "        t = x\n",
        "    else:\n",
        "        raise ValueError(\"Bubble size method must be 'linear' or 'log'\")\n",
        "\n",
        "    tmin, tmax = float(t.min()), float(t.max())\n",
        "    if np.isclose(tmin, tmax):\n",
        "        if cfg.safe_constant:\n",
        "            return pd.Series(np.full(len(t), (cfg.min_area + cfg.max_area) / 2.0), index=scale.index)\n",
        "        raise ValueError(\"Bubble size scale is constant; cannot normalize.\")\n",
        "\n",
        "    norm = (t - tmin) / (tmax - tmin)\n",
        "    return pd.Series(cfg.min_area + norm * (cfg.max_area - cfg.min_area), index=scale.index)\n",
        "\n",
        "\n",
        "def compute_market_average_yoy(df: pd.DataFrame, revenue_2024_col: str, revenue_2025_col: str) -> float:\n",
        "    \"\"\"Market Avg YoY = (sum(Y2)/sum(Y1)-1)*100\"\"\"\n",
        "    y1 = float(pd.to_numeric(df[revenue_2024_col], errors=\"coerce\").sum())\n",
        "    y2 = float(pd.to_numeric(df[revenue_2025_col], errors=\"coerce\").sum())\n",
        "    if y1 == 0:\n",
        "        raise ValueError(\"Total 2024 revenue is 0; cannot compute market average YoY.\")\n",
        "    return (y2 / y1 - 1.0) * 100.0\n",
        "\n",
        "\n",
        "# --------------------------\n",
        "# Build final (conclusive) table\n",
        "# --------------------------\n",
        "\n",
        "def build_bubble_input_table(\n",
        "    merged_df: pd.DataFrame,\n",
        "    company_col: str = \"company\",\n",
        "    revenue_2024_col: str = \"revenue_2024\",\n",
        "    revenue_2025_col: str = \"revenue_2025\",\n",
        "    market_share_mode: MarketShareMode = \"net\",\n",
        ") -> pd.DataFrame:\n",
        "    \"\"\"\n",
        "    Produces the conclusive table used for plotting.\n",
        "    Does NOT add bubble size column (derived in plot function).\n",
        "    \"\"\"\n",
        "    needed = {company_col, revenue_2024_col, revenue_2025_col}\n",
        "    if not needed.issubset(merged_df.columns):\n",
        "        raise ValueError(f\"merged_df must contain {needed}. Got: {set(merged_df.columns)}\")\n",
        "\n",
        "    df = merged_df[[company_col, revenue_2024_col, revenue_2025_col]].copy()\n",
        "\n",
        "    df[revenue_2024_col] = pd.to_numeric(df[revenue_2024_col], errors=\"coerce\")\n",
        "    df[revenue_2025_col] = pd.to_numeric(df[revenue_2025_col], errors=\"coerce\")\n",
        "    if df[[revenue_2024_col, revenue_2025_col]].isna().any().any():\n",
        "        raise ValueError(\"Revenue columns contain non-numeric or missing values.\")\n",
        "\n",
        "    df[\"absolute_growth\"] = calculate_absolute_growth(df, revenue_2024_col, revenue_2025_col)\n",
        "    df[\"yoy_growth_pct\"] = calculate_yoy_growth_pct(df, revenue_2024_col, revenue_2025_col)\n",
        "    df[\"market_growth_share_pct\"] = calculate_market_growth_share_pct(\n",
        "        df[\"absolute_growth\"], mode=market_share_mode\n",
        "    )\n",
        "\n",
        "    return df\n",
        "\n",
        "\n",
        "# --------------------------\n",
        "# Plotting (with the updates you asked)\n",
        "# --------------------------\n",
        "\n",
        "def plot_bubble_chart(\n",
        "    bubble_df: pd.DataFrame,\n",
        "    company_col: str = \"company\",\n",
        "    revenue_2024_col: str = \"revenue_2024\",\n",
        "    revenue_2025_col: str = \"revenue_2025\",\n",
        "    x_col: str = \"yoy_growth_pct\",\n",
        "    y_col: str = \"market_growth_share_pct\",\n",
        "    size_from_col: str = \"revenue_2025\",\n",
        "    size_cfg: BubbleSizeConfig = BubbleSizeConfig(),\n",
        "    plot_cfg: PlotConfig = PlotConfig(),\n",
        "    abbrev_map: Optional[Dict[str, str]] = None,\n",
        "    label_offsets: Optional[Dict[str, Tuple[float, float]]] = None,\n",
        ") -> None:\n",
        "    \"\"\"\n",
        "    Enhancements implemented:\n",
        "    - 3-shade red palette (light/medium/dark) based on quadrant vs market avg lines\n",
        "    - Short-form labels via abbrev_map\n",
        "    - Manual nudges via label_offsets (to fix PRU/SL overlap, etc.)\n",
        "    - Market Avg label positioned safely (top area, bbox)\n",
        "    - Abbreviation table on the right\n",
        "    \"\"\"\n",
        "    df = bubble_df.copy()\n",
        "\n",
        "    # Handle \"new business\" YoY NaN\n",
        "    if plot_cfg.new_business_policy == \"skip\":\n",
        "        dfp = df.dropna(subset=[x_col]).copy()\n",
        "    elif plot_cfg.new_business_policy == \"set_x_to_value\":\n",
        "        dfp = df.copy()\n",
        "        dfp[x_col] = dfp[x_col].fillna(plot_cfg.new_business_x_value)\n",
        "    else:\n",
        "        raise ValueError(\"new_business_policy must be 'skip' or 'set_x_to_value'\")\n",
        "\n",
        "    # Bubble sizes derived here\n",
        "    dfp[\"bubble_area\"] = compute_bubble_sizes(dfp[size_from_col], cfg=size_cfg)\n",
        "\n",
        "    # Market average + avg share for reference lines and criticality coloring\n",
        "    market_avg = compute_market_average_yoy(df, revenue_2024_col, revenue_2025_col)\n",
        "    n = max(1, len(dfp))\n",
        "    avg_share = 100.0 / n\n",
        "\n",
        "    # --- 3-shade red palette\n",
        "    light_red = \"#f8d7da\"\n",
        "    med_red = \"#f1aeb5\"\n",
        "    dark_red = \"#b02a37\"\n",
        "\n",
        "    def color_for_point(x: float, y: float) -> str:\n",
        "        high_x = x >= market_avg\n",
        "        high_y = y >= avg_share\n",
        "        if high_x and high_y:\n",
        "            return dark_red\n",
        "        if high_x or high_y:\n",
        "            return med_red\n",
        "        return light_red\n",
        "\n",
        "    colors = [color_for_point(float(r[x_col]), float(r[y_col])) for _, r in dfp.iterrows()]\n",
        "\n",
        "    # Figure with right margin for abbrev table\n",
        "    fig, ax = plt.subplots(figsize=(12.5, 6.5))\n",
        "    plt.subplots_adjust(right=0.78)\n",
        "\n",
        "    ax.scatter(\n",
        "        dfp[x_col],\n",
        "        dfp[y_col],\n",
        "        s=dfp[\"bubble_area\"],\n",
        "        alpha=plot_cfg.alpha,\n",
        "        c=colors,\n",
        "        edgecolors=\"white\",\n",
        "        linewidths=0.8,\n",
        "    )\n",
        "\n",
        "    # Labels: use abbreviations + offsets\n",
        "    abbrev_map = abbrev_map or {}\n",
        "    label_offsets = label_offsets or {}\n",
        "\n",
        "    for _, r in dfp.iterrows():\n",
        "        full = str(r[company_col])\n",
        "        label = abbrev_map.get(full, full)\n",
        "\n",
        "        dx, dy = label_offsets.get(label, (0.8, 0.15))\n",
        "        ax.text(\n",
        "            float(r[x_col]) + dx,\n",
        "            float(r[y_col]) + dy,\n",
        "            label,\n",
        "            fontsize=9,\n",
        "            va=\"center\",\n",
        "            ha=\"left\",\n",
        "        )\n",
        "\n",
        "    # Reference lines + safe Market Avg annotation (avoids top-middle overlap)\n",
        "    if plot_cfg.draw_market_avg_line:\n",
        "        ax.axvline(market_avg, linestyle=\"--\")\n",
        "        ymax = ax.get_ylim()[1]\n",
        "        ax.text(\n",
        "            market_avg + 0.8,\n",
        "            ymax * 0.98,\n",
        "            f\"Market Avg {market_avg:.1f}%\",\n",
        "            fontsize=10,\n",
        "            va=\"top\",\n",
        "            ha=\"left\",\n",
        "            bbox=dict(facecolor=\"white\", edgecolor=\"none\", alpha=0.85),\n",
        "        )\n",
        "\n",
        "    if plot_cfg.draw_avg_share_line:\n",
        "        ax.axhline(avg_share, linestyle=\"--\")\n",
        "\n",
        "    ax.set_title(plot_cfg.title)\n",
        "    ax.set_xlabel(plot_cfg.xlabel)\n",
        "    ax.set_ylabel(plot_cfg.ylabel)\n",
        "    if plot_cfg.grid:\n",
        "        ax.grid(True)\n",
        "\n",
        "    # Abbreviation table on right side\n",
        "    if plot_cfg.show_abbrev_table and abbrev_map:\n",
        "        present = set(dfp[company_col].astype(str).tolist())\n",
        "        rows = [(abbr, full) for full, abbr in abbrev_map.items() if full in present]\n",
        "        rows = sorted(rows, key=lambda t: t[0])\n",
        "\n",
        "        table = ax.table(\n",
        "            cellText=rows,\n",
        "            colLabels=[\"Abbrev\", \"Company\"],\n",
        "            colLoc=\"left\",\n",
        "            cellLoc=\"left\",\n",
        "            bbox=[1.02, 0.15, 0.35, 0.7],  # x, y, w, h in axes coords\n",
        "        )\n",
        "        table.auto_set_font_size(False)\n",
        "        table.set_fontsize(9)\n",
        "\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "# --------------------------\n",
        "# Example run (use this as your test harness)\n",
        "# --------------------------\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    # Raw yearly tables (synthetic, covers edge cases)\n",
        "    df_2024 = pd.DataFrame({\n",
        "        \"company\": [\n",
        "            \"HSBC Life\",\"Bank of China Life\",\"AIA\",\"Prudential\",\"Sun Life\",\"China Life\",\n",
        "            \"Hang Seng Insurance\",\"FWD\",\"YF Life\",\"AXA\",\"Manulife\",\"Tai Ping\",\n",
        "            \"New Horizon Life\",\"SteadyCare Life\",\"MegaShield Life\"\n",
        "        ],\n",
        "        \"revenue_2024\": [520,380,330,330,200,210,130,105,40,95,120,140,0,180,1200]\n",
        "    })\n",
        "\n",
        "    df_2025 = pd.DataFrame({\n",
        "        \"company\": [\n",
        "            \"HSBC Life\",\"Bank of China Life\",\"AIA\",\"Prudential\",\"Sun Life\",\"China Life\",\n",
        "            \"Hang Seng Insurance\",\"FWD\",\"YF Life\",\"AXA\",\"Manulife\",\"Tai Ping\",\n",
        "            \"New Horizon Life\",\"SteadyCare Life\",\"MegaShield Life\"\n",
        "        ],\n",
        "        \"revenue_2025\": [718,513,413,370,240,294,195,203,79,201,258,129,25,180,1320]\n",
        "    })\n",
        "\n",
        "    merged = merge_year_tables(df_2024, df_2025, join=\"inner\")\n",
        "    bubble = build_bubble_input_table(merged, market_share_mode=\"net\")\n",
        "\n",
        "    # Abbreviations (shortforms)\n",
        "    abbrev_map = {\n",
        "        \"Sun Life\": \"SL\",\n",
        "        \"Prudential\": \"PRU\",\n",
        "        \"Bank of China Life\": \"BoC\",\n",
        "        \"Hang Seng Insurance\": \"HSI\",\n",
